{
  "name": "@ds/web-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "designSystem": {
    "stability": "stable",
    "surface": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ds/core": "workspace:*",
    "@ds/primitives": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --environment jsdom"
  }
}
