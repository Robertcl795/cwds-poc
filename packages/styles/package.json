{
  "name": "@ds/styles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "designSystem": {
    "stability": "stable",
    "surface": "public"
  },
  "exports": {
    "./index.css": "./dist/index.css",
    "./tokens.css": "./dist/tokens.css",
    "./foundation/index.css": "./dist/foundation/index.css",
    "./components/index.css": "./dist/components/index.css",
    "./components/adapters.css": "./dist/components/adapters.css"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "scripts": {
    "build": "mkdir -p dist/foundation dist/components && cp src/index.css dist/index.css && cp src/tokens.css dist/tokens.css && cp src/foundation/*.css dist/foundation/ && cp src/components/*.css dist/components/",
    "lint": "stylelint \"src/**/*.css\""
  }
}
