{
  "name": "@ds/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ds/core": "workspace:*",
    "@ds/components": "workspace:*",
    "@ds/tokens": "workspace:*"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006 -c .storybook --host 127.0.0.1 --ci --no-open --exact-port --disable-telemetry --no-version-updates",
    "build-storybook": "storybook build -c .storybook --disable-telemetry"
  }
}
